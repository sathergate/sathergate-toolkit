{
  "name": "shutterbox",
  "version": "0.1.1",
  "mcpName": "io.github.sathergate/darkroom",
  "description": "Image processing pipeline for Next.js.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "bin": {
    "shutterbox": "./dist/cli.js"
  },
  "files": ["dist", "server.json"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "next": ">=14",
    "sharp": ">=0.33",
    "@modelcontextprotocol/server": ">=1.0.0",
    "zod": ">=3.25.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "@modelcontextprotocol/server": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "image",
    "processing",
    "optimization",
    "resize",
    "nextjs",
    "sharp",
    "media",
    "responsive",
    "mcp",
    "claude-code",
    "ai-coding",
    "agent-friendly",
    "sathergate-toolkit"
  ],
  "claude": {
    "init": "npx shutterbox init",
    "mcp": true,
    "category": "image-processing",
    "toolkit": {
      "name": "sathergate-toolkit",
      "repo": "https://github.com/sathergate/sathergate-toolkit",
      "packages": [
        "shutterbox",
        "flagpost",
        "ratelimit-next",
        "notifykit",
        "croncall",
        "vaultbox",
        "searchcraft"
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sathergate/darkroom"
  },
  "homepage": "https://github.com/sathergate/darkroom#readme"
}
