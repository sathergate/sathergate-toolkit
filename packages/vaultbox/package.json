{
  "name": "vaultbox",
  "version": "0.1.1",
  "mcpName": "io.github.sathergate/lockbox",
  "description": "Encrypted secrets for Next.js. No vault needed.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "bin": {
    "vaultbox": "./dist/cli.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "secrets",
    "encryption",
    "env",
    "environment",
    "vault",
    "config",
    "dotenv",
    "security",
    "mcp",
    "claude-code",
    "ai-coding",
    "agent-friendly",
    "sathergate-toolkit"
  ],
  "peerDependencies": {
    "@modelcontextprotocol/server": ">=1.0.0",
    "zod": ">=3.25.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/server": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "claude": {
    "init": "npx vaultbox init",
    "mcp": true,
    "category": "secrets-management",
    "toolkit": {
      "name": "sathergate-toolkit",
      "repo": "https://github.com/sathergate/sathergate-toolkit",
      "packages": [
        "gatehouse",
        "shutterbox",
        "flagpost",
        "ratelimit-next",
        "notifykit",
        "croncall",
        "vaultbox",
        "searchcraft"
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sathergate/lockbox"
  },
  "homepage": "https://github.com/sathergate/lockbox#readme"
}
