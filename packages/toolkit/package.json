{
  "name": "@sathergate/toolkit",
  "version": "0.1.0",
  "description": "Agent-native infrastructure toolkit for Next.js.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@modelcontextprotocol/server": ">=1.0.0",
    "zod": ">=3.25.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/server": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "nextjs",
    "toolkit",
    "agent-friendly",
    "mcp",
    "claude-code",
    "sathergate-toolkit"
  ],
  "claude": {
    "mcp": true,
    "category": "toolkit",
    "toolkit": {
      "name": "sathergate-toolkit",
      "packages": [
        "gatehouse",
        "shutterbox",
        "flagpost",
        "ratelimit-next",
        "notifykit",
        "croncall",
        "vaultbox",
        "searchcraft"
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sathergate/sathergate-toolkit"
  }
}